NODE_ENV=development
PORT=5001
CLIENT_URL=http://localhost:5173
DATABASE_DRIVER=mongodb
DATABASE_FALLBACK_TO_FILE=true
MONGO_URI=mongodb://127.0.0.1:27017/velura_crm
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
ADMIN_EMAILS=admin@example.com

SMTP_HOST=
SMTP_PORT=587
SMTP_REQUIRE_TLS=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Velura <bookings@veluraservices.com>"
CONTACT_TO=bookings@veluraservices.com

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

GOOGLE_PLACES_API_KEY=
GOOGLE_PLACE_ID=
GOOGLE_REVIEWS_CACHE_TTL_MINUTES=720
AUDIT_LOG_RETENTION_DAYS=2190
